# Student 수정
PUT http://127.0.0.1:8080/after/student/AWr8GYGVIfBOFUGuoagj
Content-Type: application/json

{
  "seq": 1,
  "name": "박석영",
  "grade": 2,
  "age": 18,
  "hobby": ["축구", "프로그래밍"]
}
